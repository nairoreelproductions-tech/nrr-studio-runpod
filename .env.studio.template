# NRR Studio Bootstrap Environment Variables
# Copy this file to .env.studio on your laptop and fill in the real values.
# NEVER commit .env.studio to git.

# Base64-encoded SSH private key for the studio-sync VPS user.
# Generate with (PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("$HOME\.ssh\studio_sync_key"))
VPS_SSH_KEY_B64=PASTE_YOUR_BASE64_KEY_HERE
